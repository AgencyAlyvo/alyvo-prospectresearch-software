{
  "name": "@alyvo/prospectresearch-software",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "web:run:dev:spa": "nuxi dev src-nuxt --dotenv .env.development --port=1470",
    "web:run:staging:spa": "nuxi dev src-nuxt --dotenv .env.staging --port=1470",
    "web:run:prod:spa": "nuxi dev src-nuxt --dotenv .env.production --port=1470",
    "web:build:static:dev": "nuxi generate src-nuxt --dotenv .env.development",
    "web:build:static:staging": "nuxi generate src-nuxt --dotenv .env.staging",
    "web:build:static:prod": "nuxi generate src-nuxt --dotenv .env.production",
    "web:analyze": "nuxi analyze src-nuxt --loglevel verbose",
    "web:cleanup": "nuxi cleanup src-nuxt",
    "web:prepare": "nuxi prepare src-nuxt",
    "desktop:run:dev": "cross-env RUST_BACKTRACE=full tauri dev",
    "desktop:check:compile": "cd src-tauri && cargo check",
    "desktop:build:windows:x64": "tauri build --target x86_64-pc-windows-msvc",
    "desktop:build:windows:arm64": "tauri build --target aarch64-pc-windows-msvc",
    "desktop:build:macos:arm64": "tauri build --target aarch64-apple-darwin",
    "desktop:build:linux:x86_64": "tauri build --target x86_64-unknown-linux-gnu",
    "desktop:build:linux:arm64": "tauri build --target aarch64-unknown-linux-gnu",
    "desktop:install:target:windows": "rustup target add x86_64-pc-windows-msvc && rustup target add aarch64-pc-windows-msvc",
    "desktop:install:target:macos": "rustup target add aarch64-apple-darwin",
    "desktop:install:target:linux": "rustup target add x86_64-unknown-linux-gnu && rustup target add aarch64-unknown-linux-gnu",
    "test:unit:dev": "vitest run --mode development",
    "test:unit:dev:watch": "vitest watch --mode development",
    "test:unit:dev:gui": "vitest --ui --mode development",
    "test:unit:staging": "vitest run --mode staging --coverage",
    "test:unit:prod": "vitest run --mode production --coverage",
    "tauri": "tauri",
    "lint:prettier": "prettier --check .",
    "lint:ts": "nuxi typecheck src-nuxt --dotenv .env.development",
    "lint:eslint": "eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "prepare": "husky && nuxi prepare src-nuxt --dotenv .env.development"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "luxon": "^3.7.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@nuxt/devtools": "^3.2.4",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^9.1.7",
    "npm-check-updates": "^22.1.1",
    "nuxt": "4.4.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sass": "^1.99.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.8"
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
